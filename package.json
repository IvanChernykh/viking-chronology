{
  "name": "viking-chronology",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive 3D Viking expansion map built with Three.js, React Three Fiber and TypeScript.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
    "standalone": "vite build --config vite.standalone.config.ts && node scripts/make-standalone.mjs",
    "check": "npm run lint && npm run typecheck && npm run build && npm run standalone && npm run verify:standalone",
    "verify:standalone": "node scripts/verify-standalone.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.7.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  }
}
